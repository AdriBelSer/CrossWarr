<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Crosswarr" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- El color primario (usado para los botones de Firebase) -->
        <item name="colorPrimary">@color/black</item>

        <!-- El color de fondo de la pantalla (evita que se vea transparente o negro) -->
        <item name="android:windowBackground">@color/white</item>

        <!-- SplashScreen configuration -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="android:windowSplashScreenAnimationDuration">1000</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/black</item>
        <item name="android:windowSplashScreenBackground">@color/black</item>

    </style>

    <style name="Theme.Crosswarr" parent="Base.Theme.Crosswarr" />
</resources>