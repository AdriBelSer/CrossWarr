<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="challenge"
            type="com.yinya.crosswarr.models.ChallengeData" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_default"
        android:layout_marginVertical="@dimen/margin_small">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_default">

            <TextView
                android:id="@+id/tv_challenge_date_card_list_challenges_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/tv_challenge_date_card_list_challenges_item"
                android:textSize="@dimen/text_size_title" />

            <TextView
                android:id="@+id/tv_challenge_status_card_list_challenges_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:text="@string/tv_challenge_status_card_list_challenges_item"
                android:textSize="@dimen/text_size_subtitle" />

            <TextView
                android:id="@+id/tv_challenge_time_card_list_challenges_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_tiny"
                android:text="@string/tv_challenge_time_card_list_challenges_item"
                android:textSize="@dimen/text_size_body"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>