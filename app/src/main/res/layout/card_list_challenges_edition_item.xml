<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="challenge"
            type="com.yinya.crosswarr.ChallengesData" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_challenge_name_card_list_challenges_edition_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tv_challenge_name_card_list_challenges_item"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_challenge_date_card_list_challenges_edition_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tv_challenge_date_card_list_challenges_item"
                    android:textSize="20sp" />


            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>
</layout>